{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL-Lab",
      "description": "Selecciona PostgreSQL-Lab al importar",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "uid": "lab-m05-03",
  "title": "Lab M05-03 — Geomap",
  "tags": [
    "lab",
    "example",
    "m05"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "geomap",
      "title": "Revenue by region (map)",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRES}"
          },
          "format": "table",
          "rawSql": "SELECT r.code AS name,\n  CASE r.code WHEN 'EMEA' THEN 50.1109 WHEN 'APAC' THEN 35.6762 WHEN 'AMER' THEN 40.7128 END AS latitude,\n  CASE r.code WHEN 'EMEA' THEN 8.6821 WHEN 'APAC' THEN 139.6503 WHEN 'AMER' THEN -74.0060 END AS longitude,\n  SUM(d.revenue)::float AS value\nFROM daily_sales d JOIN regions r ON d.region_id = r.id\nWHERE d.day > CURRENT_DATE - INTERVAL '30 days' GROUP BY r.code",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "view": {
          "id": "fit",
          "lat": 20,
          "lon": 0,
          "zoom": 1
        },
        "basemap": {
          "type": "default",
          "name": "Layer 0"
        },
        "layers": [
          {
            "type": "markers",
            "config": {
              "name": "Revenue",
              "location": {
                "mode": "coords",
                "latitude": "latitude",
                "longitude": "longitude"
              },
              "style": {
                "size": {
                  "field": "value",
                  "fixed": 5,
                  "max": 15,
                  "min": 2
                },
                "symbol": {
                  "fixed": "img/icons/marker/circle.svg",
                  "mode": "fixed"
                }
              },
              "text": {
                "field": "name"
              }
            }
          }
        ]
      }
    }
  ],
  "templating": {
    "list": []
  }
}
