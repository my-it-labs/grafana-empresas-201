{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL-Lab",
      "description": "Selecciona PostgreSQL-Lab al importar",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "uid": "lab-m05-02",
  "title": "Lab M05-02 — Tablas",
  "tags": [
    "lab",
    "example",
    "m05"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "HTTP services (3h)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT service, COUNT(*) AS requests, AVG(latency_ms)::int AS avg_ms,\n  MAX(latency_ms) AS max_ms, COUNT(*) FILTER (WHERE status >= 500) AS errors\nFROM http_events WHERE ts > NOW() - INTERVAL '3 hours'\nGROUP BY service ORDER BY errors DESC, avg_ms DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": []
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Revenue by region (30d)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT r.code AS region, SUM(d.orders) AS orders,\n  ROUND(SUM(d.revenue)::numeric, 2) AS revenue\nFROM daily_sales d JOIN regions r ON d.region_id = r.id\nWHERE d.day > CURRENT_DATE - INTERVAL '30 days'\nGROUP BY r.code ORDER BY revenue DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": []
      }
    }
  ],
  "templating": {
    "list": []
  }
}
