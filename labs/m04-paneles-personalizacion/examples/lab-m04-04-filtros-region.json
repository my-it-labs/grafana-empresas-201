{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus-Lab",
      "description": "Selecciona Prometheus-Lab al importar",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL-Lab",
      "description": "Selecciona PostgreSQL-Lab al importar",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "uid": "lab-m04-04",
  "title": "Lab M04-04 — Filtros región",
  "tags": [
    "lab",
    "example",
    "m04",
    "variables"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Revenue — $region",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRES}"
          },
          "format": "time_series",
          "rawSql": "SELECT d.day AS \"time\", SUM(d.revenue)::float AS value\nFROM daily_sales d JOIN regions r ON d.region_id = r.id\nWHERE r.code = '${region}' GROUP BY d.day ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Network TX by device",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum by (device) (rate(node_network_transmit_bytes_total{job=\"node-exporter\", device!~\"lo|veth.*\"}[5m]))",
          "legendFormat": "{{device}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "lineInterpolation": "smooth",
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "region",
        "label": "Región",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "${DS_POSTGRES}"
        },
        "query": "SELECT code AS __text, code AS __value FROM regions ORDER BY 1",
        "definition": "SELECT code AS __text, code AS __value FROM regions ORDER BY 1",
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "refresh": 1,
        "current": {},
        "options": []
      }
    ]
  }
}
