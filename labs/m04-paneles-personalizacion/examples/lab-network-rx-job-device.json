{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus-Lab",
      "description": "Selecciona Prometheus-Lab al importar",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.5.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "uid": "lab-network-rx-job-device",
  "title": "Lab — Network RX job/device",
  "tags": [
    "lab",
    "example",
    "m04",
    "network",
    "variables"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Network RX — max by device",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "max by (device) (rate(node_network_receive_bytes_total{job=~\"$job\", device=~\"$device\"}[5m]))",
          "legendFormat": "{{device}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "lineInterpolation": "smooth",
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Network RX — media y máximo por device (rango dashboard)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "datasource",
        "uid": "-- Dashboard --"
      },
      "targets": [
        {
          "datasource": {
            "type": "datasource",
            "uid": "-- Dashboard --"
          },
          "panelId": 1,
          "refId": "A",
          "withTransforms": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Máximo (B/s)"
          }
        ]
      },
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "includeTimeField": false,
            "mode": "seriesToRows",
            "reducers": [
              "mean",
              "max"
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Field": "Interfaz",
              "Mean": "Media (B/s)",
              "Max": "Máximo (B/s)"
            }
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(node_network_receive_bytes_total, job)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(node_network_receive_bytes_total, job)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {},
        "options": []
      },
      {
        "name": "device",
        "label": "Device",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(node_network_receive_bytes_total{job=~\"$job\"}, device)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "definition": "label_values(node_network_receive_bytes_total{job=~\"$job\"}, device)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1,
        "sort": 1,
        "current": {},
        "options": []
      }
    ]
  }
}
